# K3s homelab — default values (committed). Override in config/project.env.
# Scripts source this first, then project.env if present.

# SSH (all nodes). Placeholder user — override K3S_SSH_USER in config/project.env (gitignored).
K3S_SSH_USER=serendipper
K3S_SSH_KEY=~/.ssh/k3s_ed25519
K3S_SSH_KNOWN_HOSTS=~/.ssh/known_hosts

# Wi‑Fi (nodes / first-boot)
K3S_WIFI_SSID=

# Control plane (join URL, jump host, SSH by name). Set in project.env.
# K3S_CP_IP: resolve from config/nodes by K3S_CP_HOST, or set explicitly in project.env.
K3S_CP_IP=
K3S_CP_HOST=dalaran
# kubectl kubeconfig `server:` hostname (LAN DNS, e.g. Pi-hole). Must match a K3s TLS SAN.
K3S_CP_API_HOST=dalaran.lan

# Network scan (nmap to find nodes). Set in project.env.
K3S_SCAN_SUBNET=

# K3s install and API
K3S_INSTALL_URL=https://get.k3s.io
K3S_API_PORT=6443
K3S_NODE_TOKEN_PATH=/var/lib/rancher/k3s/server/node-token
