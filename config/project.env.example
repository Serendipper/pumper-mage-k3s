# K3s homelab — project config template (copy to project.env and set your values)
# project.env is gitignored; do not commit secrets.
# Scripts source config/defaults.env first, then project.env. Override only what you need.

# SSH user on all nodes
K3S_SSH_USER=serendipper

# Path to project SSH private key (create with agent-environment-setup)
K3S_SSH_KEY=~/.ssh/k3s_cluster_ed25519

# SSH known_hosts file (avoids agent context issues)
K3S_SSH_KNOWN_HOSTS=~/.ssh/known_hosts

# Node login + sudo password (for sshpass and sudo -S before keys are deployed)
# Required for initial node setup. Leave empty to pass explicitly in commands.
K3S_NODE_PASSWORD=

# Wi‑Fi for nodes. Required for initial node setup before SSH key is on the node (Pi first-boot
# cloud-init, laptop wpa_supplicant). Set in config/project.env; do not commit the real value.
K3S_WIFI_SSID=
K3S_WIFI_PSK=

# Control plane IP (for join URL and jump host). Resolve from config/nodes by K3S_CP_HOST, or set here.
K3S_CP_IP=

# kubectl kubeconfig API server hostname (default: dalaran.lan from defaults.env). Override if your LAN DNS name differs.
# K3S_CP_API_HOST=dalaran.lan

# Network scan subnet for nmap (e.g. 10.0.0.0/24). Set to match your LAN.
K3S_SCAN_SUBNET=

# PostgreSQL datastore URL (control plane only). Set when using external DB.
# K3S_DATASTORE_URL=postgres://user:password@host:5432/k3s
