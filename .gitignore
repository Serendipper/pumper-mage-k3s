# Cursor — local rules only (not shared; each clone maintains its own)
.cursor/

# Local project config (secrets); see config/project.env.example
config/project.env

# Live node list (hostname IP); agent-maintained
config/nodes

# Generated local artifacts (kubeconfigs, generated dashboards, etc.)
generated/

# Scratch folder for downloads (OS images, etc.); not tracked
downloads/

# Generated from project.env (Pi first-boot, etc.)
config/generated/

# Live Helm values (project-specific overrides); agent/maintainer only, not public
config/helm-values/

# Live cluster state (node + control plane changelogs)
nodes/
control-plane/

# Private skill (keep locally; not for public repo)
skills/sanitizing-sandbox/

# Syncthing conflict sidecars (never commit)
*.sync-conflict*

# Local TrueNAS operator helpers/docs (keep private and untracked)
scripts/private-truenas/
